                "fontSize": "16px",
                "fontWeight": "600",
                "textDecoration": "none",
                "backgroundColor": "var(--accent)",
                "color": "var(--base)",
                "border": "1px solid var(--accent)",
                "transition": "filter 200ms ease, transform 200ms ease",
                "&:hover": { "filter": "brightness(0.92)" },
                "&:focus-visible": { "outline": "2px solid var(--contrast)", "outlineOffset": "2px" }
              }
            },
            {
              "type": "element",
              "tagName": "ul",
              "styles": {
                "listStyle": "none",
                "margin": "0",
                "padding": "0",
                "display": "flex",
                "flexDirection": "column",
                "gap": "12px",
                "& li": { "position": "relative", "paddingLeft": "28px", "fontSize": "15px", "lineHeight": "1.5", "color": "var(--contrast-2)" },
                "& li::before": { "content": "\"✓\"", "position": "absolute", "left": "0", "top": "0", "fontWeight": "700", "color": "var(--accent)" }
              },
              "innerBlocks": [
                { "type": "text", "tagName": "li", "content": "<strong>Everything in Starter</strong>" },
                { "type": "text", "tagName": "li", "content": "Unlimited projects" },
                { "type": "text", "tagName": "li", "content": "Timeline &amp; calendar views" },
                { "type": "text", "tagName": "li", "content": "Workflow automation" },
                { "type": "text", "tagName": "li", "content": "Dashboards &amp; reporting" },
                { "type": "text", "tagName": "li", "content": "Priority email support" }
              ]
            }
          ]
        },
