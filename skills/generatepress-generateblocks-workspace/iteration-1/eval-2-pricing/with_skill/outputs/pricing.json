              }
            },
            {
              "type": "text",
              "tagName": "a",
              "content": "Contact sales",
              "htmlAttributes": { "href": "/contact-sales" },
              "styles": {
                "display": "block",
                "textAlign": "center",
                "padding": "13px 24px",
                "borderRadius": "10px",
                "fontSize": "16px",
                "fontWeight": "600",
                "textDecoration": "none",
                "backgroundColor": "transparent",
                "color": "var(--accent)",
