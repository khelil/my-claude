                  "type": "text",
                  "tagName": "h3",
                  "content": "Pro",
                  "styles": { "fontSize": "20px", "fontWeight": "700", "color": "var(--contrast)", "margin": "0" }
                },
                {
                  "type": "text",
                  "tagName": "p",
                  "content": "For growing teams that need automation and reporting.",
                  "styles": { "fontSize": "15px", "lineHeight": "1.5", "color": "var(--contrast-2)", "margin": "0" }
                }
              ]
            },
            {
              "type": "text",
              "tagName": "p",
              "content": "$12<span class=\"gb-price-period\">/user/mo</span>",
              "styles": {
                "fontSize": "44px",
                "fontWeight": "700",
                "lineHeight": "1",
                "color": "var(--contrast)",
                "margin": "0",
                "& .gb-price-period": { "fontSize": "16px", "fontWeight": "500", "color": "var(--contrast-3)", "marginLeft": "4px" }
              }
            },
            {
              "type": "text",
              "tagName": "a",
