          "innerBlocks": [
            {
              "type": "text",
              "tagName": "span",
              "content": "Most popular",
              "styles": {
                "position": "absolute",
                "top": "0",
                "left": "50%",
                "transform": "translate(-50%,-50%)",
                "backgroundColor": "var(--accent)",
                "color": "var(--base)",
                "fontSize": "12px",
                "fontWeight": "700",
                "letterSpacing": "0.06em",
                "textTransform": "uppercase",
                "padding": "6px 14px",
                "borderRadius": "999px",
                "whiteSpace": "nowrap"
