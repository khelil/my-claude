            "transition": "transform 200ms ease, box-shadow 200ms ease",
            "&:hover": { "transform": "scale(1.04) translateY(-4px)" },
            "@media (max-width:1024px)": { "transform": "none", "&:hover": { "transform": "translateY(-4px)" } }
